# LLMJob node environment — copy to /etc/llmjob/agent.env and chmod 600.
# Both llmjob-agent.service and llmjob-usage.service read this file.

LLMJOB_SERVER=https://llmjob-production.up.railway.app
LLMJOB_TOKEN=            # join token (agent only) — dashboard "Add Node"
LLMJOB_API_KEY=          # lj-… key for /api/usage (usage shipper only)
LLMJOB_NODE_NAME=
LLAMA_ENDPOINT=http://127.0.0.1:8000
LLAMA_UNIT=llama-qwen
LLMJOB_APP=hermes
