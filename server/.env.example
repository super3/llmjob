# Server Configuration
PORT=3001

# Postgres Configuration
# Connection string for the Postgres database (used by the app and migrations).
DATABASE_URL=postgres://localhost:5432/llmjob

# Clerk Configuration
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key

# Admin allow-list (comma-separated Clerk user ids) for admin-only routes such
# as POST /api/jobs/cleanup. Empty means no one is an admin.
ADMIN_USER_IDS=
