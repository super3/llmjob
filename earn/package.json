{
  "name": "llmjob-earn",
  "version": "0.2.4",
  "description": "LLMJob Earn — desktop GUI that turns the excess compute on GPUs you already own into crypto (Pearl / PRL) via the AlphaPool alpha-miner. Paste a payout address and start earning, no command line.",
  "main": "src/main/main.js",
  "bin": {
    "llmjob-earn-cli": "src/cli/earn-cli.js"
  },
  "scripts": {
    "start": "electron .",
    "start:cli": "node src/cli/earn-cli.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "dist:cli": "node scripts/build-cli.mjs",
    "dist:hiveos": "node scripts/build-hiveos.mjs"
  },
  "keywords": [
    "llmjob",
    "pearl",
    "prl",
    "mining",
    "alpha-miner",
    "electron",
    "gpu"
  ],
  "author": "super3",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.1",
    "jest": "^30.0.5",
    "postject": "^1.0.0-alpha.6"
  },
  "build": {
    "appId": "com.llmjob.earn",
    "productName": "LLMJob Earn",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "vendor/engine",
        "to": "engine",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "vendor/llm-runtime",
        "to": "llm-runtime",
        "filter": [
          "**/*.dll"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.ico",
      "artifactName": "LLMJob-Earn-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "src/assets/icon.ico",
      "uninstallerIcon": "src/assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/assets/icon.png",
      "category": "Utility",
      "artifactName": "LLMJob-Earn-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "super3",
        "repo": "llmjob",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  }
}
